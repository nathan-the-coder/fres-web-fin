{
  "version": 2,
  "builds": [
    {
      "src": "api/*.py",
      "use": "@vercel/python"
    },
    {
      "src": "frontend/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/ping",
      "dest": "/api/ping.py"
    },
    {
      "src": "/api/users/(.*)",
      "dest": "/api/users.py"
    },
    {
      "src": "/api/users",
      "dest": "/api/users.py"
    },
    {
      "src": "/api/ai/(.*)",
      "dest": "/api/ai.py"
    },
    {
      "src": "/api/ai",
      "dest": "/api/ai.py"
    },
    {
      "src": "/api/admin/(.*)",
      "dest": "/api/admin.py"
    },
    {
      "src": "/api/admin",
      "dest": "/api/admin.py"
    },
    {
      "src": "/api/init_db",
      "dest": "/api/init_db.py"
    },
    {
      "src": "/(.*)",
      "dest": "/frontend/$1"
    }
  ]
}
